# =============================================================================
# STARTER Ghostty Configuration
# =============================================================================
# To open this file: in Ghostty, click the menu bar, then Ghostty > Settings.
# Changes take effect when you open a new window, or immediately for some
# settings. Full documentation: https://ghostty.org/docs/config
# =============================================================================


# --- COLORS ------------------------------------------------------------------
# OPTION 1: Use a built-in theme (simplest)
# Uncomment the line below and delete everything down to OPTION 2 to use a
# pre-built theme instead of a custom palette. Browse themes visually at
# https://iterm2colorschemes.com, then find the Ghostty name at
# https://ghostty.org/docs/features/theme
#
# theme = TokyoNight

# OPTION 2: Custom palette (Claude-inspired, default)
# Ghostty uses a 16-color terminal palette (0-15).
# Colors 0-7 are normal, colors 8-15 are the "bright" variants.
# Swap any hex value to match your own brand or aesthetic.

palette = 0=#1C1B1A     # Black (background dark)
palette = 1=#DA7756     # Red (errors, warnings)
palette = 2=#6B9E7A     # Green (success, git additions)
palette = 3=#C4956A     # Yellow (warnings, modified files)
palette = 4=#8B9DC3     # Blue (links, info)
palette = 5=#C47A6B     # Magenta (special values)
palette = 6=#7AABAA     # Cyan (paths, highlights)
palette = 7=#A09890     # White (default text)
palette = 8=#2E2C2A     # Bright Black (comments, muted text)
palette = 9=#E8967C     # Bright Red
palette = 10=#85B892    # Bright Green
palette = 11=#D4A870    # Bright Yellow
palette = 12=#9BAFD4    # Bright Blue
palette = 13=#D49080    # Bright Magenta
palette = 14=#8FC4BE    # Bright Cyan
palette = 15=#F2EDE6    # Bright White (brightest text)

# The main background and foreground colors for your terminal window.
background = #1C1B1A
foreground = #F2EDE6

# The color of your cursor and the text underneath it.
cursor-color = #DA7756
cursor-text = #1C1B1A

# The highlight color when you select text.
selection-background = #2E2C2A
selection-foreground = #F2EDE6


# --- CONTRAST ----------------------------------------------------------------
# Ghostty can automatically boost the contrast of text that's hard to read.
# 1.0 = no boost, 4.5 = WCAG AA standard, 7.0 = WCAG AAA (very strong).
# 1.3 is a subtle improvement that keeps the palette looking natural.
minimum-contrast = 1.3


# --- FONT --------------------------------------------------------------------
# Set the font family by name. The font must be installed on your Mac.
# Popular monospace options: "JetBrains Mono", "Fira Code", "Cascadia Code",
# "Maple Mono", "Berkeley Mono", "Monaspace Neon"
# Leave blank to use Ghostty's built-in default font.
font-family =

# Font size in points. 13–15 is a comfortable range for most displays.
font-size = 14

# Adds a little extra vertical space between lines of text.
# Makes the terminal feel more open and easier to scan.
# Values are percentages. 8% adds a subtle but noticeable amount of breathing room.
adjust-cell-height = 8%


# --- WINDOW ------------------------------------------------------------------
# Horizontal and vertical padding (in pixels) between the text and the window edge.
# More padding = more breathing room, especially helpful on large monitors.
window-padding-x = 32
window-padding-y = 16

# Remembers your window size and position when you quit and reopen Ghostty.
window-save-state = always

# When you split your terminal into two panes side by side, this keeps the
# padding even on all sides so it doesn't look lopsided.
# Split a pane with: Cmd+D (vertical) or Cmd+Shift+D (horizontal)
window-padding-balance = true

# When using split panes, this dims the pane you're not actively typing in.
# Makes it easy to see at a glance which pane is active.
# 1.0 = fully visible, 0.0 = invisible. 0.6 is a subtle but clear difference.
unfocused-split-opacity = 0.6

# Uses the Display P3 color space for more accurate, vibrant colors on modern Macs.
# Only makes a visible difference on wide-gamut displays (most MacBooks since 2016).
window-colorspace = "display-p3"

# Applies a frosted-glass blur effect to the terminal background.
# Options: false | blur | macos-glass | macos-glass-light | macos-glass-clear
# macos-glass-clear gives the most transparent, polished look.
background-blur = macos-glass-clear

# --- LINKS -------------------------------------------------------------------
# Makes URLs in your terminal clickable. Cmd+click to open in your browser.
link-url = true


# --- SHELL INTEGRATION -------------------------------------------------------
# Ghostty can deeply integrate with your shell to add features like:
# - Clicking to jump between command outputs
# - Knowing exactly where each prompt starts
# - Smarter copy behavior
# no-cursor tells Ghostty not to manage the cursor style (we handle that below).
shell-integration-features = no-cursor


# --- CURSOR ------------------------------------------------------------------
# Shape of your text cursor.
# Options: block | bar | underline
# block is the most visible and classic terminal look.
cursor-style = block


# --- MOUSE -------------------------------------------------------------------
# Hides the mouse pointer while you're typing so it doesn't cover your text.
# It reappears as soon as you move the mouse.
mouse-hide-while-typing = true


# --- KEYBINDINGS -------------------------------------------------------------
# Customize keyboard shortcuts. Format: keybind = <keys>=<action>
# Full list of actions: https://ghostty.org/docs/config/keybind/reference

# Ensures Cmd+C and Cmd+V always copy and paste terminal text as expected.
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
